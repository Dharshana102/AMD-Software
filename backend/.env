# ================================================================
# UART COMMUNICATION CONFIGURATION
# ================================================================
 
# Communication Mode: uart (for hardware) or simulation (for testing)
COMM_MODE=simulation
 
# UART Settings (only used when COMM_MODE=uart)
UART_PORT=/dev/ttyUSB0
UART_BAUDRATE=115200
UART_TIMEOUT=2
UART_BYTESIZE=8
UART_PARITY=N
UART_STOPBITS=1
 
# ================================================================
# SERVER CONFIGURATION
# ================================================================
 
HOST=0.0.0.0
PORT=8000
DEBUG=true
 
# ================================================================
# API CONFIGURATION
# ================================================================
 
API_PREFIX=/api
API_VERSION=v1
 
# ================================================================
# LOGGING CONFIGURATION
# ================================================================
 
LOG_LEVEL=INFO
LOG_FILE=logs/app.log